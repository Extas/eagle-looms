{
  "name": "eagle-looms",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 8791",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run --environment happy-dom",
    "build": "tsc --noEmit && vite build",
    "verify:local": "npm run test:unit && npm run build && npm run verify:eagle",
    "verify:all": "npm run verify:local && npm run verify:eagle:write-smoke && npm run verify:eagle:import-smoke",
    "verify:eagle": "node scripts/verify-eagle.mjs",
    "verify:eagle:write-smoke": "node scripts/verify-eagle-write-smoke.mjs",
    "verify:eagle:import-smoke": "node scripts/verify-eagle-import-smoke.mjs",
    "preview": "vite preview --host 127.0.0.1 --port 8792"
  },
  "devDependencies": {
    "@types/file-saver": "^2.0.7",
    "@types/pica": "^9.0.5",
    "happy-dom": "^20.0.11",
    "typescript": "^5.7.3",
    "vite": "^7.3.2",
    "vite-plugin-monkey": "^7.1.9",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@zip.js/zip.js": "^2.8.26",
    "file-saver": "^2.0.5",
    "pica": "^9.0.1"
  }
}
